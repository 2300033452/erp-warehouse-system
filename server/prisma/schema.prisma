generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                Int        @id @default(autoincrement())
  name              String
  category          String
  stock             Int        @default(0)
  buyPrice          Float
  sellPrice         Float
  lowStockThreshold Int
  createdAt         DateTime   @default(now())

  sales             Sale[]
  purchases         Purchase[]
}

model Supplier {
  id                Int        @id @default(autoincrement())
  name              String
  email             String
  phone             String
  address           String
  productsSupplied  String
  createdAt         DateTime   @default(now())

  purchases         Purchase[]
}

model Purchase {
  id                   Int       @id @default(autoincrement())
  supplierId           Int
  productId            Int
  quantity             Int
  purchasePricePerUnit Float
  date                 DateTime  @default(now())

  supplier             Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product              Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Sale {
  id                  Int       @id @default(autoincrement())
  productId           Int
  soldUnits           Int
  sellingPricePerUnit Float
  soldBy              String
  date                DateTime  @default(now())

  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}
